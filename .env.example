# Firebase Client Configuration (from Firebase Console > Project Settings > Web App)
# Get these values from: Firebase Console → Project Settings → Your apps → Web app
# These values are used by the frontend auth.html via /api/firebase-config endpoint
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abc123def456

# Firebase Admin SDK (Server-side)
# Option 1: Path to your service account JSON file (for local development)
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Option 2: Full service account JSON as string (for production deployment)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Minify the JSON: cat firebase-service-account.json | jq -c
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Google Maps API Key (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Application Settings
NODE_ENV=development
PORT=3000

# Production Settings (optional, only for production deployment)
# FRONTEND_URL=https://www.suchapain.com
